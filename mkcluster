function require_arg() {
  local flag="$1"
  local value="${2:-}"

  [[ -n "${value}" ]] || die "Missing value for ${flag}"
}

function is_true() {
  case "${1,,}" in
    1|true|yes|on) return 0 ;;
    0|false|no|off) return 1 ;;
    *) die "Expected a boolean value, got: ${1}" ;;
  esac
}

function validate_positive_int() {
  local name="$1"
  local value="$2"

  [[ "${value}" =~ ^[1-9][0-9]*$ ]] || die "${name} must be a positive integer, got: ${value}"
}

function normalize_feature_gate() {
  local raw="$1"
  local name value

  if [[ "${raw}" == *=* ]]; then
    name="${raw%%=*}"
    value="${raw#*=}"
    if is_true "${value}"; then
      value=true
    else
      value=false
    fi
  else
    name="${raw}"
    value=true
  fi

  [[ -n "${name}" ]] || die "Feature gate name cannot be empty"
  printf '"%s": %s' "${name}" "${value}"
}

function feature_gate_name() {
  local raw="$1"
  printf '%s\n' "${raw%%=*}"
}

function ensure_feature_gate_default() {
  local desired_gate="$1"
  local existing_gate

  for existing_gate in "${feature_gates[@]}"; do
    if [[ "$(feature_gate_name "${existing_gate}")" == "${desired_gate}" ]]; then
      return
    fi
  done

  feature_gates+=("${desired_gate}=true")
}

function print_latest_kind_version() {
  command -v curl &>/dev/null || die "curl is required for --latest-kind-version"

  local latest_url
  latest_url="$(curl -fsSLI -o /dev/null -w '%{url_effective}\n' "${KIND_RELEASES_LATEST_URL}")" ||
    die "Failed to retrieve the latest kind release tag from ${KIND_RELEASES_LATEST_URL}"

  printf '%s\n' "${latest_url##*/}"
}

function resolve_kind_node_image() {
  local version="${1#v}"

  case "${version}" in
    latest)
      printf '%s\n' ''
      ;;
    1.35|1.35.0)
      printf '%s\n' 'kindest/node:v1.35.0@sha256:452d707d4862f52530247495d180205e029056831160e22870e37e3f6c1ac31f'
      ;;
    1.34|1.34.3)
      printf '%s\n' 'kindest/node:v1.34.3@sha256:08497ee19eace7b4b5348db5c6a1591d7752b164530a36f855cb0f2bdcbadd48'
      ;;
    1.33|1.33.7)
      printf '%s\n' 'kindest/node:v1.33.7@sha256:d26ef333bdb2cbe9862a0f7c3803ecc7b4303d8cea8e814b481b09949d353040'
      ;;
    1.32|1.32.11)
      printf '%s\n' 'kindest/node:v1.32.11@sha256:5fc52d52a7b9574015299724bd68f183702956aa4a2116ae75a63cb574b35af8'
      ;;
    1.31|1.31.14)
      printf '%s\n' 'kindest/node:v1.31.14@sha256:6f86cf509dbb42767b6e79debc3f2c32e4ee01386f0489b3b2be24b0a55aac2b'
      ;;
    *)
      die "Unsupported k8s version: ${1}. Supported values: latest, 1.35, 1.34, 1.33, 1.32, 1.31"
      ;;
  esac
}

function parse_args() {
  while (($#)); do
    case "$1" in
      -h|--help)
        usage
        exit 0
        ;;
      -l|--latest-kind-version)
        print_latest_kind_version
        exit 0
        ;;
      -g|--gpu)
        gpu_enabled=true
        shift
        ;;
      -d|--gpu-dra)
        gpu_dra_enabled=true
        shift
        ;;
      -n|--name)
        require_arg "$1" "${2:-}"
        cluster_name="$2"
        shift 2
        ;;
      --name=*)
        cluster_name="${1#*=}"
        shift
        ;;
      -i|--ip-family)
        require_arg "$1" "${2:-}"
        ip_family="$2"
        shift 2
        ;;
      --ip-family=*)
        ip_family="${1#*=}"
        shift
        ;;
      -P|--provider)
        require_arg "$1" "${2:-}"
        provider="$2"
        shift 2
        ;;
      --provider=*)
        provider="${1#*=}"
        shift
        ;;
      -k|--k8s-version)
        require_arg "$1" "${2:-}"
        kubernetes_version="$2"
        shift 2
        ;;
      --k8s-version=*)
        kubernetes_version="${1#*=}"
        shift
        ;;
      -a|--api-server-address)
        require_arg "$1" "${2:-}"
        api_server_address="$2"
        shift 2
        ;;
      --api-server-address=*)
        api_server_address="${1#*=}"
        shift
        ;;
      -p|--api-server-port)
        require_arg "$1" "${2:-}"
        api_server_port="$2"
        shift 2
        ;;
      --api-server-port=*)
        api_server_port="${1#*=}"
        shift
        ;;
      -W|--workers)
        require_arg "$1" "${2:-}"
        worker_count="$2"
        shift 2
        ;;
      --workers=*)
        worker_count="${1#*=}"
        shift
        ;;
      -f|--feature-gate)
        require_arg "$1" "${2:-}"
        feature_gates+=("$2")
        shift 2
        ;;
      --feature-gate=*)
        feature_gates+=("${1#*=}")
        shift
        ;;
      -r|--retain)
        kind_extra_args+=(--retain)
        shift
        ;;
      -w|--wait)
        require_arg "$1" "${2:-}"
        kind_extra_args+=(--wait "$2")
        shift 2
        ;;
      --wait=*)
        kind_extra_args+=(--wait "${1#*=}")
        shift
        ;;
      --)
        shift
        kind_extra_args+=("$@")
        break
        ;;
      *)
        die "Unknown argument: $1. Pass through extra kind arguments after --"
        ;;
    esac
  done
}

function validate_args() {
  [[ -n "${cluster_name}" ]] || die "Cluster name cannot be empty"
  [[ -n "${registry_name}" ]] || die "Registry name cannot be empty"

  validate_positive_int "worker count" "${worker_count}"
  validate_positive_int "registry port" "${registry_port}"
  validate_positive_int "api server port" "${api_server_port}"
  case "${ip_family}" in
    ipv4|ipv6|dual) ;;
    *) die "ip family must be one of: ipv4, ipv6, dual" ;;
  esac
  case "${provider}" in
    docker|nerdctl|podman) ;;
    *) die "provider must be one of: docker, nerdctl, podman" ;;
  esac
  kind_node_image="$(resolve_kind_node_image "${kubernetes_version}")"

  if [[ "${gpu_dra_enabled}" == true ]]; then
    gpu_enabled=true
    ensure_feature_gate_default "DRAPartitionableDevices"
    ensure_feature_gate_default "DRAConsumableCapacity"
  fi

  if ! is_true "${gpu_enabled}"; then
    gpu_enabled=false
  else
    gpu_enabled=true
  fi
}

function check_deps() {
  if [[ $OSTYPE =~ ^darwin ]]; then
    command -v kind &>/dev/null || brew install kind
    command -v kubectl &>/dev/null || brew install kubectl
  elif [[ $OSTYPE =~ ^linux ]]; then
    command -v kind &>/dev/null || go install "sigs.k8s.io/kind@${KIND_VERSION}" || warn "Install kind from your package manager"
    if ! command -v kubectl &>/dev/null; then
      curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" &&
      sudo install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl
    fi
  fi
}

function detect_container_cli() {
  if [[ -n "${CONTAINER_CLI:-}" ]]; then
    echo "${CONTAINER_CLI}"
    return
  fi

  command -v "${provider}" &>/dev/null || die "Selected provider '${provider}' is not installed or not on PATH."
  echo "${provider}"
}

function linux_preflight() {
  if [[ ! $OSTYPE =~ ^linux ]]; then
    return
  fi

  local ip_forward
  ip_forward="$(sysctl -n net.ipv4.ip_forward 2>/dev/null || true)"
  if [[ "${ip_forward}" != "1" ]]; then
    cat >&2 <<EOF
net.ipv4.ip_forward is ${ip_forward:-unset}. kind networking will fail until IP forwarding is enabled.
Run:
  sudo sysctl -w net.ipv4.ip_forward=1
To persist:
  echo 'net.ipv4.ip_forward=1' | sudo tee /etc/sysctl.d/99-kind.conf
EOF
    exit 1
  fi
}

function config_section_has_setting() {
  local file_path="$1"
  local section_name="$2"
  local setting_name="$3"
  local expected_value="$4"

  [[ -f "${file_path}" ]] || return 1

  awk \
    -v section_name="${section_name}" \
    -v setting_name="${setting_name}" \
    -v expected_value="${expected_value}" '
      function trim(value) {
        sub(/^[[:space:]]+/, "", value)
        sub(/[[:space:]]+$/, "", value)
        return value
      }

      /^[[:space:]]*#/ { next }
      /^[[:space:]]*;/ { next }
      /^[[:space:]]*\[/ {
        in_section = ($0 == "[" section_name "]")
        next
      }
      !in_section { next }
      $0 ~ "^[[:space:]]*" setting_name "[[:space:]]*=" {
        split($0, parts, "=")
        value = trim(parts[2])
        gsub(/"/, "", value)
        if (value == expected_value) {
          found = 1
          exit
        }
      }
      END {
        exit(found ? 0 : 1)
      }
    ' "${file_path}"
}

function config_root_has_setting() {
  local file_path="$1"
  local setting_name="$2"
  local expected_value="$3"

  [[ -f "${file_path}" ]] || return 1

  awk \
    -v setting_name="${setting_name}" \
    -v expected_value="${expected_value}" '
      function trim(value) {
        sub(/^[[:space:]]+/, "", value)
        sub(/[[:space:]]+$/, "", value)
        return value
      }

      /^[[:space:]]*#/ { next }
      /^[[:space:]]*;/ { next }
      /^[[:space:]]*\[/ {
        in_section = 1
        next
      }
      in_section { next }
      $0 ~ "^[[:space:]]*" setting_name "[[:space:]]*=" {
        split($0, parts, "=")
        value = trim(parts[2])
        gsub(/"/, "", value)
        if (value == expected_value) {
          found = 1
          exit
        }
      }
      END {
        exit(found ? 0 : 1)
      }
    ' "${file_path}"
}

function require_gpu_host_prereqs() {
  [[ $OSTYPE =~ ^linux ]] || die "GPU clusters are only validated on Linux hosts."

  command -v nvidia-smi &>/dev/null || die "GPU support requires nvidia-smi on the host."
  nvidia-smi -L &>/dev/null || die "nvidia-smi could not enumerate any GPUs."
  command -v nvidia-container-runtime &>/dev/null || die "GPU support requires nvidia-container-runtime on the host."

  [[ -e /dev/nvidiactl ]] || die "GPU support requires /dev/nvidiactl on the host."
  compgen -G '/dev/nvidia[0-9]*' >/dev/null || die "GPU support requires at least one /dev/nvidia<N> device on the host."

  local runtime_config='/etc/nvidia-container-runtime/config.toml'
  [[ -f "${runtime_config}" ]] || die "GPU support requires ${runtime_config}."

  config_root_has_setting "${runtime_config}" "accept-nvidia-visible-devices-as-volume-mounts" "true" ||
    die "${runtime_config} must set accept-nvidia-visible-devices-as-volume-mounts = true for this kind GPU workflow."
}

function append_gpu_mount() {
  local host_path="$1"
  local container_path="$2"

  gpu_mounts+=("${host_path}|${container_path}")
}

function append_gpu_mount_if_present() {
  local host_path="$1"
  local container_path="$2"

  [[ -n "${host_path}" && -e "${host_path}" ]] || return
  append_gpu_mount "${host_path}" "${container_path}"
}

function detect_gpu_node_library_dir() {
  case "$(uname -m)" in
    x86_64|amd64)
      printf '%s\n' '/usr/lib/x86_64-linux-gnu'
      ;;
    aarch64|arm64)
      printf '%s\n' '/usr/lib/aarch64-linux-gnu'
      ;;
    *)
      printf '%s\n' '/usr/lib64'
      ;;
  esac
}

function detect_gpu_mounts() {
  gpu_mounts=()

  local nvidia_smi_path
  local libnvidia_ml_soname_path libnvidia_ml_real_path
  local libcuda_soname_path libcuda_real_path
  local ldconfig_output
  local node_library_dir
  nvidia_smi_path="$(readlink -f "$(command -v nvidia-smi)")"
  ldconfig_output="$(ldconfig -p 2>/dev/null || true)"
  libnvidia_ml_soname_path="$(awk '/libnvidia-ml\.so\.1 \(libc6,x86-64\)/ {print $NF; exit}' <<<"${ldconfig_output}")"
  libcuda_soname_path="$(awk '/libcuda\.so\.1 \(libc6,x86-64\)/ {print $NF; exit}' <<<"${ldconfig_output}")"
  [[ -n "${libnvidia_ml_soname_path}" ]] && libnvidia_ml_real_path="$(readlink -f "${libnvidia_ml_soname_path}")"
  [[ -n "${libcuda_soname_path}" ]] && libcuda_real_path="$(readlink -f "${libcuda_soname_path}")"
  node_library_dir="$(detect_gpu_node_library_dir)"

  [[ -n "${nvidia_smi_path}" && -f "${nvidia_smi_path}" ]] || die "Could not resolve the host path for nvidia-smi."
  [[ -n "${libnvidia_ml_soname_path}" && -e "${libnvidia_ml_soname_path}" ]] || die "Could not resolve the host path for libnvidia-ml.so.1."
  [[ -n "${libcuda_soname_path}" && -e "${libcuda_soname_path}" ]] || die "Could not resolve the host path for libcuda.so.1."

  append_gpu_mount "${nvidia_smi_path}" "/usr/bin/nvidia-smi"
  append_gpu_mount "${libnvidia_ml_soname_path}" "${node_library_dir}/libnvidia-ml.so.1"
  append_gpu_mount_if_present "${libnvidia_ml_real_path}" "${node_library_dir}/$(basename "${libnvidia_ml_real_path}")"
  append_gpu_mount "${libcuda_soname_path}" "${node_library_dir}/libcuda.so.1"
  append_gpu_mount_if_present "${libcuda_real_path}" "${node_library_dir}/$(basename "${libcuda_real_path}")"
}

function require_gpu_provider_prereqs() {
  case "${container_cli}" in
    docker)
      command -v docker &>/dev/null || die "GPU support with docker requires the docker CLI."
      docker info &>/dev/null || die "docker info failed; the Docker daemon must be reachable for GPU clusters."
      [[ "$(docker info --format '{{.DefaultRuntime}}' 2>/dev/null)" == "nvidia" ]] ||
        die "Docker must use the nvidia default runtime for kind GPU nodes."
      ;;
    nerdctl)
      local containerd_config='/etc/containerd/config.toml'
      [[ -f "${containerd_config}" ]] || die "GPU support with nerdctl requires ${containerd_config}."
      grep -Eq '^[[:space:]]*default_runtime_name[[:space:]]*=[[:space:]]*"nvidia"' "${containerd_config}" ||
        die "${containerd_config} must set default_runtime_name = \"nvidia\" for kind GPU nodes."
      grep -Eq '^[[:space:]]*BinaryName[[:space:]]*=[[:space:]]*"/usr/bin/nvidia-container-runtime"' "${containerd_config}" ||
        die "${containerd_config} must configure the nvidia runtime BinaryName for kind GPU nodes."
      ;;
    podman)
      die "GPU validation is only implemented for docker and nerdctl providers; podman is not supported for mkcluster GPU mode."
      ;;
  esac
}

function require_dra_prereqs() {
  if [[ "${gpu_enabled}" != true ]]; then
    return
  fi

  command -v helm &>/dev/null || die "GPU DRA mode requires helm on the host."
}

function gpu_preflight() {
  if [[ "${gpu_enabled}" != true ]]; then
    return
  fi

  require_gpu_host_prereqs
  require_gpu_provider_prereqs
  require_dra_prereqs
  detect_gpu_mounts
}

function ensure_podman_kind_network() {
  if [[ "${container_cli}" != "podman" ]]; then
    return
  fi

  if [[ -e /proc/sys/net/ipv6/conf/all/forwarding ]]; then
    return
  fi

  local cluster_network
  cluster_network="$("${container_cli}" network inspect "${cluster_name}" 2>/dev/null || true)"

  if [[ -z "${cluster_network}" ]]; then
    "${container_cli}" network create "${cluster_name}" >/dev/null
    return
  fi

  if grep -q '"ipv6_enabled": true' <<<"${cluster_network}"; then
    if ! grep -q '"containers": {}' <<<"${cluster_network}"; then
      cat >&2 <<EOF
The existing podman network "${cluster_name}" has IPv6 enabled, but this kernel boots with IPv6 disabled.
Remove the existing cluster/network, or recreate the network without IPv6, then rerun mkcluster.
EOF
      exit 1
    fi

    "${container_cli}" network rm "${cluster_name}" >/dev/null
    "${container_cli}" network create "${cluster_name}" >/dev/null
  fi
}

function ensure_registry() {
  if [ "$("${container_cli}" inspect -f '{{.State.Running}}' "${registry_name}" 2>/dev/null || true)" != 'true' ]; then
    "${container_cli}" run \
      -d \
      --restart=always \
      -p "127.0.0.1:${registry_port}:5000" \
      --name "${registry_name}" \
      registry:2
  fi
}

function emit_kind_config() {
  cat <<EOF
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
EOF

  if (( ${#feature_gates[@]} > 0 )); then
    echo "featureGates:"
    local gate
    for gate in "${feature_gates[@]}"; do
      printf '  %s\n' "$(normalize_feature_gate "${gate}")"
    done
  fi

  cat <<EOF
networking:
  apiServerAddress: "${api_server_address}"
  apiServerPort: ${api_server_port}
  ipFamily: ${ip_family}
EOF

  cat <<EOF
nodes:
  - role: control-plane
    labels:
      ingress-ready: "true"
    extraPortMappings:
      - containerPort: 80
        hostPort: 80
      - containerPort: 443
        hostPort: 443
EOF

  local gpu_mount host_path container_path
  local worker_index
  for ((worker_index = 0; worker_index < worker_count; worker_index++)); do
    echo "  - role: worker"
    if [[ "${gpu_enabled}" == true ]]; then
      cat <<EOF
    labels:
      gpu: "true"
      nvidia.com/gpu.present: "true"
      nvidia.com/dra-kubelet-plugin: "true"
EOF
      cat <<EOF
    extraMounts:
EOF
      for gpu_mount in "${gpu_mounts[@]}"; do
        IFS='|' read -r host_path container_path <<<"${gpu_mount}"
        cat <<EOF
      - hostPath: ${host_path}
        containerPath: ${container_path}
        readOnly: true
        selinuxRelabel: false
        propagation: None
EOF
      done
    fi
  done
}

function create_cluster() {
  local create_args=(create cluster --name "${cluster_name}")
  create_args+=("${kind_extra_args[@]}")
  if [[ -n "${kind_node_image}" ]]; then
    create_args+=(--image "${kind_node_image}")
  fi
  create_args+=(--config=-)
  emit_kind_config | kind "${create_args[@]}"
}

function load_kind_nodes() {
  mapfile -t kind_nodes < <(kind get nodes --name "${cluster_name}")
  (( ${#kind_nodes[@]} > 0 )) || die "No nodes found for cluster ${cluster_name}"
}

function detect_cluster_network_name() {
  local first_node="${kind_nodes[0]}"
  local network_name=''

  # shellcheck disable=SC2016
  network_name="$("${container_cli}" inspect -f '{{range $k, $v := .NetworkSettings.Networks}}{{$k}}{{"\n"}}{{end}}' "${first_node}" 2>/dev/null | head -n1)"
  [[ -n "${network_name}" ]] || die "Could not determine the container network for node ${first_node}"

  printf '%s\n' "${network_name}"
}

function connect_registry_network() {
  cluster_network_name="$(detect_cluster_network_name)"

  if [ "$("${container_cli}" inspect -f="{{json (index .NetworkSettings.Networks \"${cluster_network_name}\")}}" "${registry_name}" 2>/dev/null || true)" = 'null' ]; then
    "${container_cli}" network connect "${cluster_network_name}" "${registry_name}"
  fi
}

function configure_registry_for_nodes() {
  local registry_dir="/etc/containerd/certs.d/localhost:${registry_port}"
  local node

  for node in "${kind_nodes[@]}"; do
    "${container_cli}" exec "${node}" mkdir -p "${registry_dir}"
    cat <<EOF | "${container_cli}" exec -i "${node}" cp /dev/stdin "${registry_dir}/hosts.toml"
[host."http://${registry_name}:5000"]
EOF
  done
}

function annotate_registry() {
  local node

  for node in "${kind_nodes[@]}"; do
    kubectl annotate --overwrite node "${node}" "kind.x-k8s.io/registry=localhost:${registry_port}"
  done
}

function document_local_registry() {
  cat <<EOF | kubectl apply -f -
apiVersion: v1
kind: ConfigMap
metadata:
  name: local-registry-hosting
  namespace: kube-public
data:
  localRegistryHosting.v1: |
    host: "localhost:${registry_port}"
    help: "https://kind.sigs.k8s.io/docs/user/local-registry/"
EOF
}

function install_nvidia_dra_driver() {
  if [[ "${gpu_enabled}" != true ]]; then
    return
  fi

  local values_file
  values_file="$(mktemp)"
  cat >"${values_file}" <<EOF
image:
  pullPolicy: IfNotPresent
kubeletPlugin:
  nodeSelector:
    nvidia.com/dra-kubelet-plugin: "true"
EOF

  info "Installing NVIDIA DRA driver via Helm..."
  helm repo add nvidia https://helm.ngc.nvidia.com/nvidia >/dev/null 2>&1 || true
  helm repo update || die "Failed to update the NVIDIA Helm repository."
  helm upgrade -i "${NVIDIA_DRA_DRIVER_RELEASE}" nvidia/nvidia-dra-driver-gpu \
    --version "${NVIDIA_DRA_DRIVER_CHART_VERSION}" \
    --namespace "${NVIDIA_DRA_DRIVER_NAMESPACE}" \
    --create-namespace \
    --set gpuResourcesEnabledOverride=true \
    --set nvidiaDriverRoot="${NVIDIA_DRA_DRIVER_ROOT}" \
    -f "${values_file}" ||
    die "Failed to install the NVIDIA DRA driver Helm chart."
  rm -f "${values_file}"
}

initialize_defaults
parse_args "$@"
validate_args
check_deps
linux_preflight
container_cli="$(detect_container_cli)"
gpu_preflight
ensure_podman_kind_network
ensure_registry
create_cluster
load_kind_nodes
connect_registry_network
configure_registry_for_nodes
annotate_registry
document_local_registry
install_nvidia_dra_driver

info "Cluster ${cluster_name} is ready."
