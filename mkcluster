  color_bracket_text=$'\033[3;94m'
  color_green=$'\033[32m'
  color_yellow=$'\033[33m'
  color_red=$'\033[31m'
else
  color_reset=''
  color_heading=''
  color_section=''
  color_label=''
  color_meta=''
  color_value_meta=''
  color_example=''
  color_literal=''
  color_comma=''
  color_bracket=''
  color_bracket_text=''
  color_green=''
  color_yellow=''
  color_red=''
fi

function info() {
  printf '%s%s%s\n' "${color_green}" "$*" "${color_reset}"
}

function warn() {
  printf '%s%s%s\n' "${color_yellow}" "$*" "${color_reset}" >&2
}

function die() {
  printf '%s%s%s\n' "${color_red}" "$*" "${color_reset}" >&2
  exit 1
}

function detect_linux_host_ip() {
  local host_ip=''

  if command -v ip &>/dev/null; then
    host_ip="$(ip -4 route get 1.1.1.1 2>/dev/null | awk '/src/ {for (i = 1; i <= NF; i++) if ($i == "src") {print $(i + 1); exit}}')"
  fi

  if [[ -z "${host_ip}" ]] && command -v hostname &>/dev/null; then
    host_ip="$(hostname -i 2>/dev/null | awk '{for (i = 1; i <= NF; i++) if ($i !~ /^127\./) {print $i; exit}}')"
  fi

  if [[ -z "${host_ip}" ]] && command -v hostname &>/dev/null; then
    host_ip="$(hostname -i 2>/dev/null | awk '{print $1}')"
  fi

  [[ -n "${host_ip}" ]] || return 1
  printf '%s\n' "${host_ip}"
}

function detect_darwin_host_ip() {
  command -v route &>/dev/null || return 1

  local default_interface host_ip
  default_interface="$(route -n get default 2>/dev/null | awk '/interface:/{print $2; exit}')"
  [[ -n "${default_interface}" ]] || return 1

  if command -v ipconfig &>/dev/null; then
    host_ip="$(ipconfig getifaddr "${default_interface}" 2>/dev/null || true)"
  fi

  if [[ -z "${host_ip}" ]] && command -v ifconfig &>/dev/null; then
    host_ip="$(ifconfig "${default_interface}" 2>/dev/null | awk '/inet / {print $2; exit}')"
  fi

  [[ -n "${host_ip}" ]] || return 1
  printf '%s\n' "${host_ip}"
}

function detect_default_api_server_address() {
  if [[ -n "${MKCLUSTER_API_SERVER_ADDRESS:-}" ]]; then
    printf '%s\n' "${MKCLUSTER_API_SERVER_ADDRESS}"
    return
  fi

  local host_ip=''
  case "${OSTYPE}" in
    linux*)
      host_ip="$(detect_linux_host_ip || true)"
      ;;
    darwin*)
      host_ip="$(detect_darwin_host_ip || true)"
      ;;
  esac

  printf '%s\n' "${host_ip:-127.0.0.1}"
}

function detect_default_cluster_name() {
  if [[ -n "${KIND_CLUSTER_NAME:-}" ]]; then
    printf '%s\n' "${KIND_CLUSTER_NAME}"
    return
  fi

  local host_name=''
  if command -v hostname &>/dev/null; then
    host_name="$(hostname 2>/dev/null || true)"
  fi

  printf '%s\n' "${host_name:-kind}"
}

function initialize_defaults() {
  DEFAULT_CLUSTER_NAME="$(detect_default_cluster_name)"
  DEFAULT_REGISTRY_NAME="${MKCLUSTER_REGISTRY_NAME:-kind-registry}"
  DEFAULT_REGISTRY_PORT="${MKCLUSTER_REGISTRY_PORT:-5001}"
  DEFAULT_WORKER_COUNT="${MKCLUSTER_WORKER_COUNT:-3}"
  DEFAULT_IP_FAMILY="${MKCLUSTER_IP_FAMILY:-ipv4}"
  DEFAULT_KUBERNETES_VERSION='latest'
  DEFAULT_API_SERVER_ADDRESS="$(detect_default_api_server_address)"
  DEFAULT_API_SERVER_PORT="${MKCLUSTER_API_SERVER_PORT:-6443}"

  cluster_name="${DEFAULT_CLUSTER_NAME}"
  registry_name="${DEFAULT_REGISTRY_NAME}"
  registry_port="${DEFAULT_REGISTRY_PORT}"
  worker_count="${DEFAULT_WORKER_COUNT}"
  gpu_enabled=false
  gpu_dra_enabled=false
  ip_family="${DEFAULT_IP_FAMILY}"
  kubernetes_version="${DEFAULT_KUBERNETES_VERSION}"
  api_server_address="${DEFAULT_API_SERVER_ADDRESS}"
  api_server_port="${DEFAULT_API_SERVER_PORT}"
}

