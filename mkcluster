DEFAULT_REGISTRY_NAME=''
DEFAULT_REGISTRY_PORT=''
DEFAULT_WORKER_COUNT=''
DEFAULT_IP_FAMILY=''
DEFAULT_KUBERNETES_VERSION=''
DEFAULT_API_SERVER_ADDRESS=''
DEFAULT_API_SERVER_PORT=''

cluster_name=''
registry_name=''
registry_port=''
worker_count=''
gpu_enabled=false
gpu_dra_enabled=false
ip_family=''
kubernetes_version=''
kind_node_image=''
api_server_address=''
api_server_port=''
container_cli=''

kind_extra_args=()
kind_nodes=()
feature_gates=()

if [[ -t 1 ]]; then
  color_reset=$'\033[0m'
  color_heading=$'\033[1;96m'
  color_section=$'\033[1;94m'
  color_label=$'\033[1;95m'
  color_meta=$'\033[3;90m'
  color_value_meta=$'\033[3;31m'
