if [[ -t 1 ]]; then
  color_reset=$'\033[0m'
  color_heading=$'\033[1;96m'
  color_section=$'\033[1;94m'
  color_label=$'\033[1;95m'
  color_meta=$'\033[3;90m'
  color_value_meta=$'\033[3;31m'
  color_example=$'\033[3;90m'
  color_literal=$'\033[1;33m'
  color_comma=$'\033[0;37m'
  color_bracket=$'\033[1;32m'
  color_bracket_text=$'\033[3;94m'
  color_green=$'\033[32m'
  color_yellow=$'\033[33m'
  color_red=$'\033[31m'
else
  color_reset=''
  color_heading=''
  color_section=''
  color_label=''
  color_meta=''
  color_value_meta=''
  color_example=''
  color_literal=''
  color_comma=''
  color_bracket=''
  color_bracket_text=''
  color_green=''
  color_yellow=''
  color_red=''
fi

function info() {
  printf '%s%s%s\n' "${color_green}" "$*" "${color_reset}"
}

function warn() {
  printf '%s%s%s\n' "${color_yellow}" "$*" "${color_reset}" >&2
}

function die() {
  printf '%s%s%s\n' "${color_red}" "$*" "${color_reset}" >&2
  exit 1
}

# Short style helpers keep usage text readable without changing the renderer.
function hd() {
  printf '%s%s%s' "${color_heading}" "$*" "${color_reset}"
}

function sc() {
  printf '%s%s%s' "${color_section}" "$*" "${color_reset}"
}

function lb() {
  printf '%s%s%s' "${color_label}" "$*" "${color_reset}"
}

function mt() {
  printf '%s%s%s' "${color_meta}" "$*" "${color_reset}"
}

function ex() {
  printf '%s%s%s' "${color_example}" "$*" "${color_reset}"
}

function lt() {
  printf '%s%s%s' "${color_literal}" "$*" "${color_reset}"
}

function bk() {
  printf '%s[%s%s%s%s%s]%s' \
    "${color_bracket}" "${color_reset}" "${color_bracket_text}" "$*" \
    "${color_reset}" "${color_bracket}" "${color_reset}"
}

function df() {
  printf '%s(%s%s%s%s%s)%s' \
    "${color_meta}" "${color_reset}" "${color_value_meta}" "$*" \
    "${color_reset}" "${color_meta}" "${color_reset}"
}

function bm() {
  local name="$1"
  local value="$2"

  printf '%s%s%s%s[%s%s%s%s]%s' \
    "${color_meta}" "${name}" "${color_reset}" \
    "${color_bracket}" "${color_reset}" \
    "${color_bracket_text}" "${value}" "${color_reset}${color_bracket}" \
    "${color_reset}"
}

function op() {
  local short="$1"
  local long="$2"
  local meta_plain="$3"
  local description="$4"
  local meta="${5:-}"
  local label_plain="${short}, ${long}"
  local label="${color_label}${short}${color_comma},${color_reset} ${color_label}${long}${color_reset}"

  if [[ -n "${meta_plain}" ]]; then
    label_plain+=" ${meta_plain}"
    label+=" ${meta:-$(mt "${meta_plain}")}"
  fi

  print_option "${label_plain}" "${label}" "${description}"
}

function lo() {
  local long="$1"
  local meta_plain="$2"
  local description="$3"
  local meta="${4:-}"
  local label_plain="${long}"
  local label="${color_label}${long}${color_reset}"

  if [[ -n "${meta_plain}" ]]; then
    label_plain+=" ${meta_plain}"
    label+=" ${meta:-$(mt "${meta_plain}")}"
  fi

  print_option "${label_plain}" "${label}" "${description}"
}

function spaces() {
  local count="$1"
  local padding=''

  while ((count > 0)); do
    padding+=' '
    ((count--))
  done

  printf '%s' "${padding}"
}

function strip_ansi() {
  printf '%s' "$1" | sed $'s/\x1b\\[[0-9;]*m//g'
}

function visible_length() {
  local plain
  plain="$(strip_ansi "$1")"
  printf '%s' "${#plain}"
}

function print_wrapped_text() {
  local first_indent="$1"
  local continuation_indent="$2"
  local width="$3"
  local text="$4"
  local line=''
  local word=''
  local candidate=''
  local line_indent="${first_indent}"
  local -a words=()

  read -r -a words <<< "${text}"

  for word in "${words[@]}"; do
    if [[ -z "${line}" ]]; then
      candidate="${word}"
    else
      candidate="${line} ${word}"
    fi

    if [[ -n "${line}" ]] && (($(visible_length "${candidate}") > width)); then
      printf '%s%s\n' "${line_indent}" "${line}"
      line="${word}"
      line_indent="${continuation_indent}"
    else
      line="${candidate}"
    fi
  done

  printf '%s%s\n' "${line_indent}" "${line}"
}

function print_option() {
  local label_plain="$1"
  local label="$2"
  local description="$3"
  local continuation_indent
  continuation_indent="$(spaces "$((2 + OPTION_LABEL_WIDTH + 1))")"

  printf '  %s' "${label}"

  if ((${#label_plain} >= OPTION_LABEL_WIDTH)); then
    printf '\n'
    print_wrapped_text "${continuation_indent}" "${continuation_indent}" "${OPTION_DESC_WIDTH}" "${description}"
  else
    spaces "$((OPTION_LABEL_WIDTH - ${#label_plain} + 1))"
    print_wrapped_text '' "${continuation_indent}" "${OPTION_DESC_WIDTH}" "${description}"
  fi
}

function detect_linux_host_ip() {
  local host_ip=''

  if command -v ip &>/dev/null; then
    host_ip="$(ip -4 route get 1.1.1.1 2>/dev/null | awk '/src/ {for (i = 1; i <= NF; i++) if ($i == "src") {print $(i + 1); exit}}')"
  fi

  if [[ -z "${host_ip}" ]] && command -v hostname &>/dev/null; then
    host_ip="$(hostname -i 2>/dev/null | awk '{for (i = 1; i <= NF; i++) if ($i !~ /^127\./) {print $i; exit}}')"
  fi

  if [[ -z "${host_ip}" ]] && command -v hostname &>/dev/null; then
    host_ip="$(hostname -i 2>/dev/null | awk '{print $1}')"
  fi

  [[ -n "${host_ip}" ]] || return 1
  printf '%s\n' "${host_ip}"
}

function detect_darwin_host_ip() {
  command -v route &>/dev/null || return 1

  local default_interface host_ip
  default_interface="$(route -n get default 2>/dev/null | awk '/interface:/{print $2; exit}')"
  [[ -n "${default_interface}" ]] || return 1

  if command -v ipconfig &>/dev/null; then
    host_ip="$(ipconfig getifaddr "${default_interface}" 2>/dev/null || true)"
  fi

  if [[ -z "${host_ip}" ]] && command -v ifconfig &>/dev/null; then
    host_ip="$(ifconfig "${default_interface}" 2>/dev/null | awk '/inet / {print $2; exit}')"
  fi

  [[ -n "${host_ip}" ]] || return 1
  printf '%s\n' "${host_ip}"
}

function detect_default_api_server_address() {
  if [[ -n "${MKCLUSTER_API_SERVER_ADDRESS:-}" ]]; then
    printf '%s\n' "${MKCLUSTER_API_SERVER_ADDRESS}"
    return
  fi

  local host_ip=''
  case "${OSTYPE}" in
    linux*)
      host_ip="$(detect_linux_host_ip || true)"
      ;;
    darwin*)
      host_ip="$(detect_darwin_host_ip || true)"
      ;;
  esac

  printf '%s\n' "${host_ip:-127.0.0.1}"
}

function detect_default_cluster_name() {
  if [[ -n "${KIND_CLUSTER_NAME:-}" ]]; then
    printf '%s\n' "${KIND_CLUSTER_NAME}"
    return
  fi

  local host_name=''
  if command -v hostname &>/dev/null; then
    host_name="$(hostname 2>/dev/null || true)"
  fi

  printf '%s\n' "${host_name:-kind}"
}

function initialize_defaults() {
  detect_remote_defaults

  DEFAULT_CLUSTER_NAME="$(detect_default_cluster_name)"
  DEFAULT_REGISTRY_NAME="${MKCLUSTER_REGISTRY_NAME:-kind-registry}"
  DEFAULT_REGISTRY_PORT="${MKCLUSTER_REGISTRY_PORT:-5001}"
  DEFAULT_WORKER_COUNT="${MKCLUSTER_WORKER_COUNT:-3}"
  DEFAULT_IP_FAMILY="${MKCLUSTER_IP_FAMILY:-ipv4}"
  DEFAULT_PROVIDER="${KIND_EXPERIMENTAL_PROVIDER:-docker}"
  DEFAULT_API_SERVER_ADDRESS="$(detect_default_api_server_address)"
  DEFAULT_API_SERVER_PORT="${MKCLUSTER_API_SERVER_PORT:-6443}"

  cluster_name="${DEFAULT_CLUSTER_NAME}"
  registry_name="${DEFAULT_REGISTRY_NAME}"
  registry_port="${DEFAULT_REGISTRY_PORT}"
  worker_count="${DEFAULT_WORKER_COUNT}"
  gpu_enabled=false
  gpu_dra_enabled=false
  ip_family="${DEFAULT_IP_FAMILY}"
  kubernetes_version="${DEFAULT_KUBERNETES_VERSION}"
  provider="${DEFAULT_PROVIDER}"
  api_server_address="${DEFAULT_API_SERVER_ADDRESS}"
  api_server_port="${DEFAULT_API_SERVER_PORT}"
}

function usage() {
  cat <<EOF
$(hd mkcluster)
$(ex 'Create a local kind cluster with an attached local registry and a small wrapper')
$(ex 'around the more useful kind knobs.')

$(sc Usage)
  $(lb mkcluster) $(bk options) $(bk 'kind create cluster args...')

$(ex 'Pass extra ')$(lb 'kind create cluster')$(ex ' arguments only after ')$(lb --)$(ex '.')

$(sc Options)
EOF
  op -g --gpu '' "Install the NVIDIA DRA driver and label all worker nodes with $(lt gpu=true) $(df disabled)"
  op -d --gpu-dra '' "Install the NVIDIA DRA driver, enable experimental GPU DRA gates, and set $(lt gpu=true)"
  op -n --name NAME "Set the cluster name $(df "${DEFAULT_CLUSTER_NAME}")"
  op -i --ip-family FAMILY "Set the kind networking $(lt ipFamily) $(df "${DEFAULT_IP_FAMILY}")"
  op -k --k8s-version VERSION "Set the k8s version to deploy $(df "${DEFAULT_KUBERNETES_VERSION}")"
  op -P --provider PROVIDER "Set the container provider $(df "${DEFAULT_PROVIDER}")"
  op -a --api-server-address IP "Bind the k8s API server to a host IP $(df "${DEFAULT_API_SERVER_ADDRESS}")"
  op -p --api-server-port PORT "Publish the API server on a fixed host port $(df "${DEFAULT_API_SERVER_PORT}")"
  op -W --workers COUNT "Set the worker node count $(df "${DEFAULT_WORKER_COUNT}")"
  op -f --feature-gate 'GATE[=BOOL]' 'Enable or disable a k8s feature gate' "$(bm GATE '=BOOL')"
  op -l --latest-kind-version '' 'Print the latest kind release tag and exit'
  op -L --latest-versions '' 'Print detected latest kind, k8s, and NVIDIA DRA versions'
  lo --repair-gpu-mounts '' 'Refresh worker NVIDIA libraries and restart DRA pods'
  op -r --retain '' 'Retain nodes when cluster creation fails'
  op -w --wait DURATION "Wait for cluster readiness, e.g. $(lt 5m)"
  op -h --help '' 'Show this help'
  cat <<EOF

$(sc Examples)
  $(ex mkcluster)
  $(ex 'mkcluster -g')
  $(ex 'mkcluster -d')
  $(ex 'mkcluster -k 1.34')
  $(ex 'mkcluster -P nerdctl')
  $(ex 'mkcluster --feature-gate MemoryQoS=true')
  $(ex 'mkcluster -n dev --retain')
  $(ex 'mkcluster --repair-gpu-mounts')
  $(ex 'HOST_IP=192.0.2.10 mkcluster -n dev -i dual -a "$HOST_IP" -p 6443 --wait 5m')
  $(ex 'mkcluster -- --verbosity=4')
EOF
}

function require_arg() {
  local flag="$1"
  local value="${2:-}"

  [[ -n "${value}" ]] || die "Missing value for ${flag}"
}

function is_true() {
  case "${1,,}" in
    1|true|yes|on) return 0 ;;
    0|false|no|off) return 1 ;;
    *) die "Expected a boolean value, got: ${1}" ;;
  esac
}

function validate_positive_int() {
  local name="$1"
  local value="$2"

  [[ "${value}" =~ ^[1-9][0-9]*$ ]] || die "${name} must be a positive integer, got: ${value}"
}

function normalize_feature_gate() {
  local raw="$1"
  local name value

  if [[ "${raw}" == *=* ]]; then
    name="${raw%%=*}"
    value="${raw#*=}"
    if is_true "${value}"; then
      value=true
    else
      value=false
    fi
  else
    name="${raw}"
    value=true
  fi

  [[ -n "${name}" ]] || die "Feature gate name cannot be empty"
  printf '"%s": %s' "${name}" "${value}"
}

function feature_gate_name() {
  local raw="$1"
  printf '%s\n' "${raw%%=*}"
}

function ensure_feature_gate_default() {
  local desired_gate="$1"
  local existing_gate

  for existing_gate in "${feature_gates[@]}"; do
    if [[ "$(feature_gate_name "${existing_gate}")" == "${desired_gate}" ]]; then
      return
    fi
  done

  feature_gates+=("${desired_gate}=true")
}

function fetch_url() {
  local url="$1"

  command -v curl &>/dev/null || return 1
  curl -fsSL --connect-timeout "${REMOTE_LOOKUP_TIMEOUT}" --max-time "${REMOTE_LOOKUP_TIMEOUT}" "${url}" 2>/dev/null
}

function fetch_effective_url() {
  local url="$1"

  command -v curl &>/dev/null || return 1
  curl -fsSLI -o /dev/null -w '%{url_effective}\n' \
    --connect-timeout "${REMOTE_LOOKUP_TIMEOUT}" \
    --max-time "${REMOTE_LOOKUP_TIMEOUT}" \
    "${url}" 2>/dev/null
}

function kind_release_tag_from_json() {
  local release_json="$1"

  sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' <<<"${release_json}" | head -n1
}

function kind_node_images_from_release() {
  local release_text="$1"

  grep -Eo 'kindest/node:v[0-9]+\.[0-9]+\.[0-9]+@sha256:[[:xdigit:]]{64}' <<<"${release_text}" |
    awk '!seen[$0]++'
}

function kind_node_image_k8s_version() {
  local image="$1"

  sed -n 's/.*kindest\/node:v\([0-9][0-9.]*\)@sha256:.*/\1/p' <<<"${image}" | head -n1
}

function detect_latest_kind_version() {
  local release_json="${1:-}"
  local version=''

  if [[ -n "${release_json}" ]]; then
    version="$(kind_release_tag_from_json "${release_json}")"
  fi

  if [[ -z "${version}" ]]; then
    local latest_url
    latest_url="$(fetch_effective_url "${KIND_RELEASES_LATEST_URL}")" || return 1
    version="${latest_url##*/}"
  fi

  [[ -n "${version}" ]] || return 1
  printf '%s\n' "${version}"
}

function detect_latest_kind_node_image() {
  local release_json="${1:-}"

  [[ -n "${release_json}" ]] || release_json="$(fetch_url "${KIND_RELEASES_API_LATEST_URL}")" || return 1
  kind_node_images_from_release "${release_json}" | head -n1
}

function detect_latest_k8s_version() {
  local release_json="${1:-}"
  local node_image=''

  node_image="$(detect_latest_kind_node_image "${release_json}" || true)"
  [[ -n "${node_image}" ]] || return 1
  kind_node_image_k8s_version "${node_image}"
}

function detect_latest_nvidia_dra_driver_chart_version() {
  local index_yaml

  index_yaml="$(fetch_url "${NVIDIA_HELM_INDEX_URL}")" || return 1
  awk -v chart="${NVIDIA_DRA_DRIVER_RELEASE}" '
    $0 ~ "^  " chart ":" {
      in_chart = 1
      next
    }
    in_chart && /^  [^[:space:]-][^:]*:/ {
      exit
    }
    in_chart && /^[[:space:]]*-[[:space:]]*version:/ {
      gsub(/"/, "", $3)
      print $3
      exit
    }
    in_chart && /^[[:space:]]+version:/ {
      gsub(/"/, "", $2)
      print $2
      exit
    }
  ' <<<"${index_yaml}"
}

function print_latest_kind_version() {
  local version
  version="$(detect_latest_kind_version "${KIND_LATEST_RELEASE_JSON}" || true)"

  [[ -n "${version}" ]] ||
    die "Failed to retrieve the latest kind release tag from ${KIND_RELEASES_LATEST_URL}"

  printf '%s\n' "${version}"
}

function print_latest_versions() {
  local kind_version=''
  local node_image=''
  local k8s_version=''
  local dra_chart_version=''

  kind_version="$(detect_latest_kind_version "${KIND_LATEST_RELEASE_JSON}" || true)"
  node_image="$(detect_latest_kind_node_image "${KIND_LATEST_RELEASE_JSON}" || true)"
  k8s_version="$(kind_node_image_k8s_version "${node_image}" || true)"
  dra_chart_version="$(detect_latest_nvidia_dra_driver_chart_version || true)"

  [[ -n "${kind_version}" ]] || die "Failed to retrieve the latest kind release tag."
  [[ -n "${k8s_version}" ]] || die "Failed to retrieve the latest kind node image k8s version."
  [[ -n "${dra_chart_version}" ]] || die "Failed to retrieve the latest NVIDIA DRA Helm chart version."

  printf 'kind %s\n' "${kind_version}"
  printf 'k8s %s\n' "${k8s_version}"
  printf 'nvidia-dra %s\n' "${dra_chart_version}"
}

function resolve_kind_release_node_image() {
  local version="${1#v}"
  local escaped_version="${version//./\\.}"
  local version_pattern=''

  [[ -n "${KIND_LATEST_RELEASE_JSON}" ]] || return 1

  if [[ "${version}" =~ ^[0-9]+\.[0-9]+$ ]]; then
    version_pattern="v${escaped_version}\\.[0-9]+"
  elif [[ "${version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    version_pattern="v${escaped_version}"
  else
    return 1
  fi

  kind_node_images_from_release "${KIND_LATEST_RELEASE_JSON}" |
    grep -E "kindest/node:${version_pattern}@sha256:[[:xdigit:]]{64}" |
    head -n1
}

function resolve_kind_node_image() {
  local version="${1#v}"
  local release_node_image=''

  case "${version}" in
    latest)
      printf '%s\n' "${DEFAULT_KIND_NODE_IMAGE}"
      ;;
    *)
      release_node_image="$(resolve_kind_release_node_image "${version}" || true)"
      if [[ -n "${release_node_image}" ]]; then
        printf '%s\n' "${release_node_image}"
        return
      fi

      case "${version}" in
        1.36|1.36.1)
          printf '%s\n' 'kindest/node:v1.36.1@sha256:3489c7674813ba5d8b1a9977baea8a6e553784dab7b84759d1014dbd78f7ebd5'
          ;;
        1.35|1.35.5)
          printf '%s\n' 'kindest/node:v1.35.5@sha256:ce977ae6d65918d0b58a5f8b5e940429c2ce42fa3a5619ec2bbc60b949c0ac95'
          ;;
        1.34|1.34.8)
          printf '%s\n' 'kindest/node:v1.34.8@sha256:02722c2dedddcfc00febf5d27fbeb9b7b2c14294c82109ff4a85d89ac9ba3256'
          ;;
        1.33|1.33.12)
          printf '%s\n' 'kindest/node:v1.33.12@sha256:3f5c8443c620245e4d355cfe09e96a91ead32ceaa569d3f1ca9edf0cb2fe2ff4'
          ;;
        1.32|1.32.11)
          printf '%s\n' 'kindest/node:v1.32.11@sha256:5fc52d52a7b9574015299724bd68f183702956aa4a2116ae75a63cb574b35af8'
          ;;
        1.31|1.31.14)
          printf '%s\n' 'kindest/node:v1.31.14@sha256:6f86cf509dbb42767b6e79debc3f2c32e4ee01386f0489b3b2be24b0a55aac2b'
          ;;
        *)
          die "Unsupported k8s version: ${1}. Supported values: latest, 1.36, 1.35, 1.34, 1.33, 1.32, 1.31"
          ;;
      esac
      ;;
  esac
}

function detect_remote_defaults() {
  local detected_kind_version=''
  local detected_k8s_version=''
  local detected_dra_chart_version=''

  if [[ "${action}" == "repair_gpu_mounts" ]]; then
    KIND_VERSION="${MKCLUSTER_KIND_VERSION:-${FALLBACK_KIND_VERSION}}"
    DEFAULT_KUBERNETES_VERSION="${MKCLUSTER_K8S_VERSION:-${MKCLUSTER_KUBERNETES_VERSION:-latest}}"
    NVIDIA_DRA_DRIVER_CHART_VERSION="${MKCLUSTER_NVIDIA_DRA_DRIVER_CHART_VERSION:-${FALLBACK_NVIDIA_DRA_DRIVER_CHART_VERSION}}"
    return
  fi

  if [[ -z "${MKCLUSTER_KIND_VERSION:-}" && -z "${MKCLUSTER_KIND_NODE_IMAGE:-}" ]]; then
    KIND_LATEST_RELEASE_JSON="$(fetch_url "${KIND_RELEASES_API_LATEST_URL}" || true)"
  fi

  detected_kind_version="${MKCLUSTER_KIND_VERSION:-}"
  if [[ -z "${detected_kind_version}" ]]; then
    detected_kind_version="$(detect_latest_kind_version "${KIND_LATEST_RELEASE_JSON}" || true)"
  fi
  KIND_VERSION="${detected_kind_version:-${FALLBACK_KIND_VERSION}}"

  DEFAULT_KIND_NODE_IMAGE="${MKCLUSTER_KIND_NODE_IMAGE:-}"
  if [[ -z "${DEFAULT_KIND_NODE_IMAGE}" && -n "${KIND_LATEST_RELEASE_JSON}" ]]; then
    DEFAULT_KIND_NODE_IMAGE="$(detect_latest_kind_node_image "${KIND_LATEST_RELEASE_JSON}" || true)"
  fi

  detected_k8s_version="${MKCLUSTER_K8S_VERSION:-${MKCLUSTER_KUBERNETES_VERSION:-}}"
  if [[ -z "${detected_k8s_version}" ]]; then
    detected_k8s_version="$(kind_node_image_k8s_version "${DEFAULT_KIND_NODE_IMAGE}" || true)"
  fi
  DEFAULT_KUBERNETES_VERSION="${detected_k8s_version:-latest}"

  detected_dra_chart_version="${MKCLUSTER_NVIDIA_DRA_DRIVER_CHART_VERSION:-}"
  if [[ -z "${detected_dra_chart_version}" ]]; then
    detected_dra_chart_version="$(detect_latest_nvidia_dra_driver_chart_version || true)"
  fi
  NVIDIA_DRA_DRIVER_CHART_VERSION="${detected_dra_chart_version:-${FALLBACK_NVIDIA_DRA_DRIVER_CHART_VERSION}}"
}

function prescan_action() {
  while (($#)); do
    case "$1" in
      --repair-gpu-mounts)
        action='repair_gpu_mounts'
        ;;
      --)
        break
        ;;
    esac
    shift
  done
}

function parse_args() {
  while (($#)); do
    case "$1" in
      -h|--help)
        usage
        exit 0
        ;;
      -l|--latest-kind-version)
        print_latest_kind_version
        exit 0
        ;;
      -L|--latest-versions)
        print_latest_versions
        exit 0
        ;;
      --repair-gpu-mounts)
        action='repair_gpu_mounts'
        shift
        ;;
      -g|--gpu)
        gpu_enabled=true
        shift
        ;;
      -d|--gpu-dra)
        gpu_dra_enabled=true
        shift
        ;;
      -n|--name)
        require_arg "$1" "${2:-}"
        cluster_name="$2"
        shift 2
        ;;
      --name=*)
        cluster_name="${1#*=}"
        shift
        ;;
      -i|--ip-family)
        require_arg "$1" "${2:-}"
        ip_family="$2"
        shift 2
        ;;
      --ip-family=*)
        ip_family="${1#*=}"
        shift
        ;;
      -P|--provider)
        require_arg "$1" "${2:-}"
        provider="$2"
        shift 2
        ;;
      --provider=*)
        provider="${1#*=}"
        shift
        ;;
      -k|--k8s-version)
        require_arg "$1" "${2:-}"
        kubernetes_version="$2"
        shift 2
        ;;
      --k8s-version=*)
        kubernetes_version="${1#*=}"
        shift
        ;;
      -a|--api-server-address)
        require_arg "$1" "${2:-}"
        api_server_address="$2"
        shift 2
        ;;
      --api-server-address=*)
        api_server_address="${1#*=}"
        shift
        ;;
      -p|--api-server-port)
        require_arg "$1" "${2:-}"
        api_server_port="$2"
        shift 2
        ;;
      --api-server-port=*)
        api_server_port="${1#*=}"
        shift
        ;;
      -W|--workers)
        require_arg "$1" "${2:-}"
        worker_count="$2"
        shift 2
        ;;
      --workers=*)
        worker_count="${1#*=}"
        shift
        ;;
      -f|--feature-gate)
        require_arg "$1" "${2:-}"
        feature_gates+=("$2")
        shift 2
        ;;
      --feature-gate=*)
        feature_gates+=("${1#*=}")
        shift
        ;;
      -r|--retain)
        kind_extra_args+=(--retain)
        shift
        ;;
      -w|--wait)
        require_arg "$1" "${2:-}"
        kind_extra_args+=(--wait "$2")
        shift 2
        ;;
      --wait=*)
        kind_extra_args+=(--wait "${1#*=}")
        shift
        ;;
      --)
        shift
        kind_extra_args+=("$@")
        break
        ;;
      *)
        die "Unknown argument: $1. Pass through extra kind arguments after --"
        ;;
    esac
  done
}

function validate_args() {
  [[ -n "${cluster_name}" ]] || die "Cluster name cannot be empty"
  [[ -n "${registry_name}" ]] || die "Registry name cannot be empty"

  validate_positive_int "worker count" "${worker_count}"
  validate_positive_int "registry port" "${registry_port}"
  validate_positive_int "api server port" "${api_server_port}"
  case "${ip_family}" in
    ipv4|ipv6|dual) ;;
    *) die "ip family must be one of: ipv4, ipv6, dual" ;;
  esac
  case "${provider}" in
    docker|nerdctl|podman) ;;
    *) die "provider must be one of: docker, nerdctl, podman" ;;
  esac
  kind_node_image="$(resolve_kind_node_image "${kubernetes_version}")"

  if [[ "${gpu_dra_enabled}" == true ]]; then
    gpu_enabled=true
    ensure_feature_gate_default "DRAPartitionableDevices"
    ensure_feature_gate_default "DRAConsumableCapacity"
  fi

  if ! is_true "${gpu_enabled}"; then
    gpu_enabled=false
  else
    gpu_enabled=true
  fi
}

function check_deps() {
  if [[ $OSTYPE =~ ^darwin ]]; then
    command -v kind &>/dev/null || brew install kind
    command -v kubectl &>/dev/null || brew install kubectl
  elif [[ $OSTYPE =~ ^linux ]]; then
    command -v kind &>/dev/null || go install "sigs.k8s.io/kind@${KIND_VERSION}" || warn "Install kind from your package manager"
    if ! command -v kubectl &>/dev/null; then
      curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" &&
      sudo install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl
    fi
  fi
}

function detect_container_cli() {
  if [[ -n "${CONTAINER_CLI:-}" ]]; then
    echo "${CONTAINER_CLI}"
    return
  fi

  command -v "${provider}" &>/dev/null || die "Selected provider '${provider}' is not installed or not on PATH."
  echo "${provider}"
}

function linux_preflight() {
  if [[ ! $OSTYPE =~ ^linux ]]; then
    return
  fi

  local ip_forward
  ip_forward="$(sysctl -n net.ipv4.ip_forward 2>/dev/null || true)"
  if [[ "${ip_forward}" != "1" ]]; then
    cat >&2 <<EOF
net.ipv4.ip_forward is ${ip_forward:-unset}. kind networking will fail until IP forwarding is enabled.
Run:
  sudo sysctl -w net.ipv4.ip_forward=1
To persist:
  echo 'net.ipv4.ip_forward=1' | sudo tee /etc/sysctl.d/99-kind.conf
EOF
    exit 1
  fi
}

function config_section_has_setting() {
  local file_path="$1"
  local section_name="$2"
  local setting_name="$3"
  local expected_value="$4"

  [[ -f "${file_path}" ]] || return 1

  awk \
    -v section_name="${section_name}" \
    -v setting_name="${setting_name}" \
    -v expected_value="${expected_value}" '
      function trim(value) {
        sub(/^[[:space:]]+/, "", value)
        sub(/[[:space:]]+$/, "", value)
        return value
      }

      /^[[:space:]]*#/ { next }
      /^[[:space:]]*;/ { next }
      /^[[:space:]]*\[/ {
        in_section = ($0 == "[" section_name "]")
        next
      }
      !in_section { next }
      $0 ~ "^[[:space:]]*" setting_name "[[:space:]]*=" {
        split($0, parts, "=")
        value = trim(parts[2])
        gsub(/"/, "", value)
        if (value == expected_value) {
          found = 1
          exit
        }
      }
      END {
        exit(found ? 0 : 1)
      }
    ' "${file_path}"
}

function config_root_has_setting() {
  local file_path="$1"
  local setting_name="$2"
  local expected_value="$3"

  [[ -f "${file_path}" ]] || return 1

  awk \
    -v setting_name="${setting_name}" \
    -v expected_value="${expected_value}" '
      function trim(value) {
        sub(/^[[:space:]]+/, "", value)
        sub(/[[:space:]]+$/, "", value)
        return value
      }

      /^[[:space:]]*#/ { next }
      /^[[:space:]]*;/ { next }
      /^[[:space:]]*\[/ {
        in_section = 1
        next
      }
      in_section { next }
      $0 ~ "^[[:space:]]*" setting_name "[[:space:]]*=" {
        split($0, parts, "=")
        value = trim(parts[2])
        gsub(/"/, "", value)
        if (value == expected_value) {
          found = 1
          exit
        }
      }
      END {
        exit(found ? 0 : 1)
      }
    ' "${file_path}"
}

function require_gpu_host_prereqs() {
  [[ $OSTYPE =~ ^linux ]] || die "GPU clusters are only validated on Linux hosts."

  command -v nvidia-smi &>/dev/null || die "GPU support requires nvidia-smi on the host."
  nvidia-smi -L &>/dev/null || die "nvidia-smi could not enumerate any GPUs."
  command -v nvidia-container-runtime &>/dev/null || die "GPU support requires nvidia-container-runtime on the host."

  [[ -e /dev/nvidiactl ]] || die "GPU support requires /dev/nvidiactl on the host."
  compgen -G '/dev/nvidia[0-9]*' >/dev/null || die "GPU support requires at least one /dev/nvidia<N> device on the host."

  local runtime_config='/etc/nvidia-container-runtime/config.toml'
  [[ -f "${runtime_config}" ]] || die "GPU support requires ${runtime_config}."

  config_root_has_setting "${runtime_config}" "accept-nvidia-visible-devices-as-volume-mounts" "true" ||
    die "${runtime_config} must set accept-nvidia-visible-devices-as-volume-mounts = true for this kind GPU workflow."
}

function append_gpu_mount() {
  local host_path="$1"
  local container_path="$2"

  gpu_mounts+=("${host_path}|${container_path}")
}

function append_gpu_mount_if_present() {
  local host_path="$1"
  local container_path="$2"

  [[ -n "${host_path}" && -e "${host_path}" ]] || return
  append_gpu_mount "${host_path}" "${container_path}"
}

function detect_gpu_node_library_dir() {
  case "$(uname -m)" in
    x86_64|amd64)
      printf '%s\n' '/usr/lib/x86_64-linux-gnu'
      ;;
    aarch64|arm64)
      printf '%s\n' '/usr/lib/aarch64-linux-gnu'
      ;;
    *)
      printf '%s\n' '/usr/lib64'
      ;;
  esac
}

function detect_gpu_mounts() {
  gpu_mounts=()

  local nvidia_smi_path
  local libnvidia_ml_soname_path libnvidia_ml_real_path
  local libcuda_soname_path libcuda_real_path
  local ldconfig_output
  local node_library_dir
  nvidia_smi_path="$(readlink -f "$(command -v nvidia-smi)")"
  ldconfig_output="$(ldconfig -p 2>/dev/null || true)"
  libnvidia_ml_soname_path="$(awk '/libnvidia-ml\.so\.1 \(libc6,x86-64\)/ {print $NF; exit}' <<<"${ldconfig_output}")"
  libcuda_soname_path="$(awk '/libcuda\.so\.1 \(libc6,x86-64\)/ {print $NF; exit}' <<<"${ldconfig_output}")"
  [[ -n "${libnvidia_ml_soname_path}" ]] && libnvidia_ml_real_path="$(readlink -f "${libnvidia_ml_soname_path}")"
  [[ -n "${libcuda_soname_path}" ]] && libcuda_real_path="$(readlink -f "${libcuda_soname_path}")"
  node_library_dir="$(detect_gpu_node_library_dir)"

  [[ -n "${nvidia_smi_path}" && -f "${nvidia_smi_path}" ]] || die "Could not resolve the host path for nvidia-smi."
  [[ -n "${libnvidia_ml_soname_path}" && -e "${libnvidia_ml_soname_path}" ]] || die "Could not resolve the host path for libnvidia-ml.so.1."
  [[ -n "${libcuda_soname_path}" && -e "${libcuda_soname_path}" ]] || die "Could not resolve the host path for libcuda.so.1."

  append_gpu_mount "${nvidia_smi_path}" "/usr/bin/nvidia-smi"
  append_gpu_mount "${libnvidia_ml_soname_path}" "${node_library_dir}/libnvidia-ml.so.1"
  append_gpu_mount_if_present "${libnvidia_ml_real_path}" "${node_library_dir}/$(basename "${libnvidia_ml_real_path}")"
  append_gpu_mount "${libcuda_soname_path}" "${node_library_dir}/libcuda.so.1"
  append_gpu_mount_if_present "${libcuda_real_path}" "${node_library_dir}/$(basename "${libcuda_real_path}")"
}

function require_gpu_repair_prereqs() {
  [[ $OSTYPE =~ ^linux ]] || die "GPU mount repair is only implemented on Linux hosts."

  command -v kind &>/dev/null || die "GPU mount repair requires kind on the host."
  command -v kubectl &>/dev/null || die "GPU mount repair requires kubectl on the host."
  command -v nvidia-smi &>/dev/null || die "GPU mount repair requires nvidia-smi on the host."
  command -v ldconfig &>/dev/null || die "GPU mount repair requires ldconfig on the host."
  command -v readlink &>/dev/null || die "GPU mount repair requires readlink on the host."
  nvidia-smi -L &>/dev/null || die "nvidia-smi could not enumerate any GPUs."
}

function is_worker_node_container() {
  local node="$1"

  [[ "${node}" != *control-plane* ]]
}

function repair_gpu_mount_file() {
  local node="$1"
  local host_path="$2"
  local container_path="$3"
  local resolved_host_path=''
  local container_dir=''

  resolved_host_path="$(readlink -f "${host_path}")"
  [[ -n "${resolved_host_path}" && -f "${resolved_host_path}" ]] ||
    die "Could not resolve repair source file: ${host_path}"

  container_dir="${container_path%/*}"
  info "Repairing ${node}:${container_path} from ${resolved_host_path}"
  "${container_cli}" exec "${node}" mkdir -p "${container_dir}"
  "${container_cli}" exec "${node}" rm -f "${container_path}"
  "${container_cli}" cp "${resolved_host_path}" "${node}:${container_path}"
}

function repair_worker_gpu_mounts() {
  local node=''
  local gpu_mount=''
  local host_path=''
  local container_path=''
  local repaired_workers=0

  for node in "${kind_nodes[@]}"; do
    is_worker_node_container "${node}" || continue
    ((repaired_workers += 1))
    for gpu_mount in "${gpu_mounts[@]}"; do
      IFS='|' read -r host_path container_path <<<"${gpu_mount}"
      repair_gpu_mount_file "${node}" "${host_path}" "${container_path}"
    done
  done

  ((repaired_workers > 0)) || die "No worker containers found for cluster ${cluster_name}"
}

function restart_nvidia_dra_pods() {
  local context="kind-${cluster_name}"
  local daemonset_name="${NVIDIA_DRA_DRIVER_RELEASE}-kubelet-plugin"
  local -a pods=()

  if ! kubectl --context "${context}" get namespace "${NVIDIA_DRA_DRIVER_NAMESPACE}" >/dev/null 2>&1; then
    warn "Namespace ${NVIDIA_DRA_DRIVER_NAMESPACE} was not found; skipping DRA pod restart."
    return
  fi

  mapfile -t pods < <(
    kubectl --context "${context}" -n "${NVIDIA_DRA_DRIVER_NAMESPACE}" get pods -o name 2>/dev/null |
      grep "^pod/${daemonset_name}-" || true
  )

  if (( ${#pods[@]} == 0 )); then
    warn "No ${daemonset_name} pods found to restart."
  else
    kubectl --context "${context}" -n "${NVIDIA_DRA_DRIVER_NAMESPACE}" delete "${pods[@]}" --wait=false
  fi

  if kubectl --context "${context}" -n "${NVIDIA_DRA_DRIVER_NAMESPACE}" get daemonset "${daemonset_name}" >/dev/null 2>&1; then
    kubectl --context "${context}" -n "${NVIDIA_DRA_DRIVER_NAMESPACE}" rollout status "daemonset/${daemonset_name}" --timeout=2m ||
      warn "Timed out waiting for ${daemonset_name} rollout; check pod logs for remaining DRA issues."
  fi
}

function repair_gpu_mounts() {
  require_gpu_repair_prereqs
  container_cli="$(detect_container_cli)"
  detect_gpu_mounts
  load_kind_nodes
  repair_worker_gpu_mounts
  restart_nvidia_dra_pods
  info "GPU mounts repaired for cluster ${cluster_name}."
}

function require_gpu_provider_prereqs() {
  case "${container_cli}" in
    docker)
      command -v docker &>/dev/null || die "GPU support with docker requires the docker CLI."
      docker info &>/dev/null || die "docker info failed; the Docker daemon must be reachable for GPU clusters."
      [[ "$(docker info --format '{{.DefaultRuntime}}' 2>/dev/null)" == "nvidia" ]] ||
        die "Docker must use the nvidia default runtime for kind GPU nodes."
      ;;
    nerdctl)
      local containerd_config='/etc/containerd/config.toml'
      [[ -f "${containerd_config}" ]] || die "GPU support with nerdctl requires ${containerd_config}."
      grep -Eq '^[[:space:]]*default_runtime_name[[:space:]]*=[[:space:]]*"nvidia"' "${containerd_config}" ||
        die "${containerd_config} must set default_runtime_name = \"nvidia\" for kind GPU nodes."
      grep -Eq '^[[:space:]]*BinaryName[[:space:]]*=[[:space:]]*"/usr/bin/nvidia-container-runtime"' "${containerd_config}" ||
        die "${containerd_config} must configure the nvidia runtime BinaryName for kind GPU nodes."
      ;;
    podman)
      die "GPU validation is only implemented for docker and nerdctl providers; podman is not supported for mkcluster GPU mode."
      ;;
  esac
}

function require_dra_prereqs() {
  if [[ "${gpu_enabled}" != true ]]; then
    return
  fi

  command -v helm &>/dev/null || die "GPU DRA mode requires helm on the host."
}

function gpu_preflight() {
  if [[ "${gpu_enabled}" != true ]]; then
    return
  fi

  require_gpu_host_prereqs
  require_gpu_provider_prereqs
  require_dra_prereqs
  detect_gpu_mounts
}

function ensure_podman_kind_network() {
  if [[ "${container_cli}" != "podman" ]]; then
    return
  fi

  if [[ -e /proc/sys/net/ipv6/conf/all/forwarding ]]; then
    return
  fi

  local cluster_network
  cluster_network="$("${container_cli}" network inspect "${cluster_name}" 2>/dev/null || true)"

  if [[ -z "${cluster_network}" ]]; then
    "${container_cli}" network create "${cluster_name}" >/dev/null
    return
  fi

  if grep -q '"ipv6_enabled": true' <<<"${cluster_network}"; then
    if ! grep -q '"containers": {}' <<<"${cluster_network}"; then
      cat >&2 <<EOF
The existing podman network "${cluster_name}" has IPv6 enabled, but this kernel boots with IPv6 disabled.
Remove the existing cluster/network, or recreate the network without IPv6, then rerun mkcluster.
EOF
      exit 1
    fi

    "${container_cli}" network rm "${cluster_name}" >/dev/null
    "${container_cli}" network create "${cluster_name}" >/dev/null
  fi
}

function ensure_registry() {
  if [ "$("${container_cli}" inspect -f '{{.State.Running}}' "${registry_name}" 2>/dev/null || true)" != 'true' ]; then
    "${container_cli}" run \
      -d \
      --restart=always \
      -p "127.0.0.1:${registry_port}:5000" \
      --name "${registry_name}" \
      registry:2
  fi
}

function emit_kind_config() {
  cat <<EOF
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
EOF

  if (( ${#feature_gates[@]} > 0 )); then
    echo "featureGates:"
    local gate
    for gate in "${feature_gates[@]}"; do
      printf '  %s\n' "$(normalize_feature_gate "${gate}")"
    done
  fi

  cat <<EOF
networking:
  apiServerAddress: "${api_server_address}"
  apiServerPort: ${api_server_port}
  ipFamily: ${ip_family}
EOF

  cat <<EOF
nodes:
  - role: control-plane
    labels:
      ingress-ready: "true"
    extraPortMappings:
      - containerPort: 80
        hostPort: 80
      - containerPort: 443
        hostPort: 443
EOF

  local gpu_mount host_path container_path
  local worker_index
  for ((worker_index = 0; worker_index < worker_count; worker_index++)); do
    echo "  - role: worker"
    if [[ "${gpu_enabled}" == true ]]; then
      cat <<EOF
    labels:
      gpu: "true"
      nvidia.com/gpu.present: "true"
      nvidia.com/dra-kubelet-plugin: "true"
EOF
      cat <<EOF
    extraMounts:
EOF
      for gpu_mount in "${gpu_mounts[@]}"; do
        IFS='|' read -r host_path container_path <<<"${gpu_mount}"
        cat <<EOF
      - hostPath: ${host_path}
        containerPath: ${container_path}
        readOnly: true
        selinuxRelabel: false
        propagation: None
EOF
      done
    fi
  done
}

function create_cluster() {
  local create_args=(create cluster --name "${cluster_name}")
  create_args+=("${kind_extra_args[@]}")
  if [[ -n "${kind_node_image}" ]]; then
    create_args+=(--image "${kind_node_image}")
  fi
  create_args+=(--config=-)
  emit_kind_config | kind "${create_args[@]}"
}

function load_kind_nodes() {
  mapfile -t kind_nodes < <(kind get nodes --name "${cluster_name}")
  (( ${#kind_nodes[@]} > 0 )) || die "No nodes found for cluster ${cluster_name}"
}

function detect_cluster_network_name() {
  local first_node="${kind_nodes[0]}"
  local network_name=''

  # shellcheck disable=SC2016
  network_name="$("${container_cli}" inspect -f '{{range $k, $v := .NetworkSettings.Networks}}{{$k}}{{"\n"}}{{end}}' "${first_node}" 2>/dev/null | head -n1)"
  [[ -n "${network_name}" ]] || die "Could not determine the container network for node ${first_node}"

  printf '%s\n' "${network_name}"
}

function connect_registry_network() {
  cluster_network_name="$(detect_cluster_network_name)"

  if [ "$("${container_cli}" inspect -f="{{json (index .NetworkSettings.Networks \"${cluster_network_name}\")}}" "${registry_name}" 2>/dev/null || true)" = 'null' ]; then
    "${container_cli}" network connect "${cluster_network_name}" "${registry_name}"
  fi
}

function configure_registry_for_nodes() {
  local registry_dir="/etc/containerd/certs.d/localhost:${registry_port}"
  local node

  for node in "${kind_nodes[@]}"; do
    "${container_cli}" exec "${node}" mkdir -p "${registry_dir}"
    cat <<EOF | "${container_cli}" exec -i "${node}" cp /dev/stdin "${registry_dir}/hosts.toml"
[host."http://${registry_name}:5000"]
EOF
  done
}

function annotate_registry() {
  local node

  for node in "${kind_nodes[@]}"; do
    kubectl annotate --overwrite node "${node}" "kind.x-k8s.io/registry=localhost:${registry_port}"
  done
}

function document_local_registry() {
  cat <<EOF | kubectl apply -f -
apiVersion: v1
kind: ConfigMap
metadata:
  name: local-registry-hosting
  namespace: kube-public
data:
  localRegistryHosting.v1: |
    host: "localhost:${registry_port}"
    help: "https://kind.sigs.k8s.io/docs/user/local-registry/"
EOF
}

function install_nvidia_dra_driver() {
  if [[ "${gpu_enabled}" != true ]]; then
    return
  fi

  local values_file
  values_file="$(mktemp)"
  cat >"${values_file}" <<EOF
image:
  pullPolicy: IfNotPresent
kubeletPlugin:
  nodeSelector:
    nvidia.com/dra-kubelet-plugin: "true"
EOF

  info "Installing NVIDIA DRA driver ${NVIDIA_DRA_DRIVER_CHART_VERSION} via Helm..."
  helm repo add nvidia https://helm.ngc.nvidia.com/nvidia >/dev/null 2>&1 || true
  helm repo update || die "Failed to update the NVIDIA Helm repository."
  helm upgrade -i "${NVIDIA_DRA_DRIVER_RELEASE}" nvidia/nvidia-dra-driver-gpu \
    --version "${NVIDIA_DRA_DRIVER_CHART_VERSION}" \
    --namespace "${NVIDIA_DRA_DRIVER_NAMESPACE}" \
    --create-namespace \
    --set gpuResourcesEnabledOverride=true \
    --set nvidiaDriverRoot="${NVIDIA_DRA_DRIVER_ROOT}" \
    -f "${values_file}" ||
    die "Failed to install the NVIDIA DRA driver Helm chart."
  rm -f "${values_file}"
}

prescan_action "$@"
initialize_defaults
parse_args "$@"
validate_args
if [[ "${action}" == "repair_gpu_mounts" ]]; then
  repair_gpu_mounts
  exit 0
fi
check_deps
linux_preflight
container_cli="$(detect_container_cli)"
gpu_preflight
ensure_podman_kind_network
ensure_registry
create_cluster
load_kind_nodes
connect_registry_network
configure_registry_for_nodes
annotate_registry
document_local_registry
install_nvidia_dra_driver

info "Cluster ${cluster_name} is ready."
