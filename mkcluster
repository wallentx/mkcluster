function info() {
  printf '%s%s%s\n' "${color_green}" "$*" "${color_reset}"
}

function warn() {
  printf '%s%s%s\n' "${color_yellow}" "$*" "${color_reset}" >&2
}

function die() {
  printf '%s%s%s\n' "${color_red}" "$*" "${color_reset}" >&2
  exit 1
}

function spaces() {
  local count="$1"
  local padding=''

  while ((count > 0)); do
    padding+=' '
    ((count--))
  done

  printf '%s' "${padding}"
}

function strip_ansi() {
  printf '%s' "$1" | sed $'s/\x1b\\[[0-9;]*m//g'
}

function visible_length() {
  local plain
  plain="$(strip_ansi "$1")"
  printf '%s' "${#plain}"
}

function print_wrapped_text() {
  local first_indent="$1"
  local continuation_indent="$2"
  local width="$3"
  local text="$4"
  local line=''
  local word=''
  local candidate=''
  local line_indent="${first_indent}"
  local -a words=()

  read -r -a words <<< "${text}"

  for word in "${words[@]}"; do
    if [[ -z "${line}" ]]; then
      candidate="${word}"
    else
      candidate="${line} ${word}"
    fi

    if [[ -n "${line}" ]] && (($(visible_length "${candidate}") > width)); then
      printf '%s%s\n' "${line_indent}" "${line}"
      line="${word}"
      line_indent="${continuation_indent}"
    else
      line="${candidate}"
    fi
  done

  printf '%s%s\n' "${line_indent}" "${line}"
}

function print_option() {
  local label_plain="$1"
  local label="$2"
  local description="$3"
  local continuation_indent
  continuation_indent="$(spaces "$((2 + OPTION_LABEL_WIDTH + 1))")"

  printf '  %s' "${label}"

  if ((${#label_plain} >= OPTION_LABEL_WIDTH)); then
    printf '\n'
    print_wrapped_text "${continuation_indent}" "${continuation_indent}" "${OPTION_DESC_WIDTH}" "${description}"
  else
    spaces "$((OPTION_LABEL_WIDTH - ${#label_plain} + 1))"
    print_wrapped_text '' "${continuation_indent}" "${OPTION_DESC_WIDTH}" "${description}"
  fi
}

function detect_linux_host_ip() {
  local host_ip=''

  if command -v ip &>/dev/null; then
    host_ip="$(ip -4 route get 1.1.1.1 2>/dev/null | awk '/src/ {for (i = 1; i <= NF; i++) if ($i == "src") {print $(i + 1); exit}}')"
  fi

  if [[ -z "${host_ip}" ]] && command -v hostname &>/dev/null; then
    host_ip="$(hostname -i 2>/dev/null | awk '{for (i = 1; i <= NF; i++) if ($i !~ /^127\./) {print $i; exit}}')"
  fi

  if [[ -z "${host_ip}" ]] && command -v hostname &>/dev/null; then
    host_ip="$(hostname -i 2>/dev/null | awk '{print $1}')"
  fi

  [[ -n "${host_ip}" ]] || return 1
  printf '%s\n' "${host_ip}"
}

function detect_darwin_host_ip() {
  command -v route &>/dev/null || return 1

  local default_interface host_ip
  default_interface="$(route -n get default 2>/dev/null | awk '/interface:/{print $2; exit}')"
  [[ -n "${default_interface}" ]] || return 1

  if command -v ipconfig &>/dev/null; then
    host_ip="$(ipconfig getifaddr "${default_interface}" 2>/dev/null || true)"
  fi

  if [[ -z "${host_ip}" ]] && command -v ifconfig &>/dev/null; then
    host_ip="$(ifconfig "${default_interface}" 2>/dev/null | awk '/inet / {print $2; exit}')"
  fi

  [[ -n "${host_ip}" ]] || return 1
  printf '%s\n' "${host_ip}"
}

function detect_default_api_server_address() {
  if [[ -n "${MKCLUSTER_API_SERVER_ADDRESS:-}" ]]; then
    printf '%s\n' "${MKCLUSTER_API_SERVER_ADDRESS}"
    return
  fi

  local host_ip=''
  case "${OSTYPE}" in
    linux*)
      host_ip="$(detect_linux_host_ip || true)"
      ;;
    darwin*)
      host_ip="$(detect_darwin_host_ip || true)"
      ;;
  esac

  printf '%s\n' "${host_ip:-127.0.0.1}"
}

function detect_default_cluster_name() {
  if [[ -n "${KIND_CLUSTER_NAME:-}" ]]; then
    printf '%s\n' "${KIND_CLUSTER_NAME}"
    return
  fi

  local host_name=''
  if command -v hostname &>/dev/null; then
    host_name="$(hostname 2>/dev/null || true)"
  fi

  printf '%s\n' "${host_name:-kind}"
}

